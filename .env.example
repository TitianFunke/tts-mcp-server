# The Things Stack Configuration
# Copy this file to .env and fill in your values

# Base URL of your Things Stack instance
# Common values:
# - https://eu1.cloud.thethings.network (Europe)
# - https://nam1.cloud.thethings.network (North America)
# - https://au1.cloud.thethings.network (Australia)
# - Or your own self-hosted instance URL
TTS_BASE_URL=https://eu1.cloud.thethings.network

# Your API Key (get this from your Things Stack Console)
# Go to: Console -> User Settings -> API Keys -> Add API Key
# Required permissions: Read/Write for Applications, Devices, and Gateways
TTS_API_KEY=NNSXS.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
